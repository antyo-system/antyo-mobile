{
  "expo": {
    "name": "ANTYO Focus",
    "slug": "antyomobile",
    "version": "1.12.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "antyomobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.antyo.focus",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow ANTYO Focus to access your camera to passively track your focus."
      }
    },
    "android": {
      "versionCode": 20,
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.antyo.focus",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-localization",
      "expo-notifications",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react native",
          "organization": "antyo"
        }
      ],
      "@sentry/react-native",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "TimerWidget",
              "label": "ANTYO Timer",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "description": "Active timer focus",
              "previewImage": "./assets/images/icon.png"
            }
          ]
        }
      ],
      "./node_modules/@heojeongbo/expo-live-activity/plugin/build/index.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7d231261-3e82-4637-a557-25b391551200"
      }
    }
  }
}